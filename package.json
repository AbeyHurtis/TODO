{
  "name": "TODO",
  "displayName": "TODO",
  "description": "TODO",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "todo-explorer",
          "title": "TODO",
          "icon": "resources/todo.svg"
        }
      ]
    },
    "views": {
      "todo-explorer": [
        {
          "type": "webview",
          "id": "todo.taskList",
          "name": "Tasks"
        }
      ]
    },
    "commands": [
      {
        "command": "todo.addTask",
        "title": "Add Task"
      },
      {
        "command": "todo.clearCompleted",
        "title": "Clear Completed"
      },
      {
        "command": "todo.clearActive",
        "title": "Clear Active Tasks"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.100.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "mocha": "^11.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "overrides": {
    "serialize-javascript": "7.0.4",
    "diff": "5.2.0"
  }
}
